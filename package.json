{
  "name": "games",
  "version": "1.0.0",
  "description": "Source for the web-component games embedded in the docsify site.",
  "private": true,
  "scripts": {
    "build": "webpack --env production && npm run copy:docs",
    "build:dev": "webpack",
    "watch": "webpack --watch",
    "copy:docs": "mkdir -p docs/assets/js && cp dist/dbs-full-bundle.js docs/assets/js/"
  },
  "dependencies": {
    "@aurelia/web-components": "^2.0.0-beta.25",
    "aurelia": "latest"
  },
  "devDependencies": {
    "@aurelia/webpack-loader": "latest",
    "@babel/core": "^7.26.0",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-class-properties": "^7.25.9",
    "@babel/plugin-transform-class-static-block": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "autoprefixer": "^10.4.20",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4"
  }
}
